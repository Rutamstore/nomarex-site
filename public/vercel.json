{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/kr", "destination": "/kr/index.html" }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
